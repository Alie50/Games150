<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    tools:context=".MainActivity">

    <!-- Setup Screen -->
    <FrameLayout
        android:id="@+id/setupScreen"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            android:layout_gravity="center"
            app:cardCornerRadius="36dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingBottom="32dp">

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎲 النقاط والمربعات"
                    android:textSize="28sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/subtitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تحريك الخط بشكل حي"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="24dp" />

                <!-- Player 1 Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/player1Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center_horizontal">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/player1Number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            app:cardCornerRadius="30dp"
                            app:cardElevation="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:textSize="14sp"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                android:padding="8dp" />
                        </androidx.cardview.widget.CardView>

                        <EditText
                            android:id="@+id/p1Name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:background="@null"
                            android:hint="اسم اللاعب 1"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:padding="12dp"
                            android:paddingEnd="0dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_marginTop="8dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="لون اللاعب 1:"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary" />
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/p1Color"
                                    android:layout_width="52dp"
                                    android:layout_height="38dp"
                                    android:background="@null"
                                    android:textColor="@color/p1_default"
                                    android:inputType="text"
                                    android:imeOptions="actionDone" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Player 2 Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/player2Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center_horizontal">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/player2Number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            app:cardCornerRadius="30dp"
                            app:cardElevation="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2"
                                android:textSize="14sp"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                android:padding="8dp" />
                        </androidx.cardview.widget.CardView>

                        <EditText
                            android:id="@+id/p2Name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:background="@null"
                            android:hint="اسم اللاعب 2"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:padding="12dp"
                            android:paddingEnd="0dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_marginTop="8dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="لون اللاعب 2:"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary" />
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/p2Color"
                                    android:layout_width="52dp"
                                    android:layout_height="38dp"
                                    android:background="@null"
                                    android:textColor="@color/p2_default"
                                    android:inputType="text"
                                    android:imeOptions="actionDone" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Grid Size Options -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/gridOptionsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📏 حجم الشبكة:"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_marginTop="8dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSize4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4x4"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/btn_option_background"
                                android:layout_margin="4dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSize6"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="6x6"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/btn_option_selected_background"
                                android:layout_margin="4dp" />
                            
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSize8"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8x8"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/btn_option_background"
                                android:layout_margin="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Start Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/startBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🚀 ابدأ اللعبة"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/btn_start_background"
                    android:layout_marginTop="16dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <!-- Game Container -->
    <FrameLayout
        android:id="@+id/gameContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Score Board -->
        <LinearLayout
            android:id="@+id/scoreBoard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:orientation="horizontal"
            android:gravity="center">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardP1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/scoreP1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="30sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="1dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/divider" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardP2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/scoreP2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="30sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Turn Indicator -->
        <androidx.cardview.widget.CardView
            android:id="@+id/turnIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/scoreBoard"
            android:layout_marginHorizontal="32dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="40dp"
            app:cardElevation="2dp">
            <TextView
                android:id="@+id/turnText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="دور: اللاعب 1"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="12dp" />
        </androidx.cardview.widget.CardView>

        <!-- Game Board -->
        <FrameLayout
            android:id="@+id/boardContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_below="@+id/turnIndicator"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/board"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/white">
                    <!-- Dots and lines will be added dynamically -->
                    <View
                        android:id="@+id/previewLine"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone" />
                    
                    <!-- Touch areas will be added dynamically -->
                </FrameLayout>
            </androidx.cardview.widget.CardView>
        </FrameLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>